# Telegram bot token from @BotFather
BOT_TOKEN=

# Restrict bot controls to one Telegram user id. Set 0 to allow all users.
BOT_OWNER_ID=0

# Telegram API credentials from https://my.telegram.org
# These remain on the server. End users do not need them.
TG_API_ID=
TG_API_HASH=

# Encryption key for stored Telegram StringSession values
# Generate with:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SESSION_SECRET=

# Google service account credentials file path
GOOGLE_CREDENTIALS_FILE=google-service-account.json

# SQLite database path for multitenant storage
DATABASE_PATH=app.db

# Runtime behavior
BATCH_SIZE=200
MAX_BATCH_SIZE=200
SLEEP_BETWEEN_REQUESTS_SEC=1.5
REQUEST_JITTER_SEC=0.75
IMPORT_COOLDOWN_SEC=1800
DELETE_COOLDOWN_SEC=21600
LOGIN_CODE_COOLDOWN_SEC=60
